{
  "manifest_version": 2,
  "name": "TurboDown - Firefox Integration",
  "version": "1.0",
  "description": "Integrates Firefox downloads with TurboDown Download Manager for faster, resumable downloads.",
  "permissions": [
    "downloads",
    "contextMenus",
    "storage",
    "notifications",
    "http://127.0.0.1:9000/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ]
}
